+
+namespace matopt_tool {
+namespace {
+class json_cursor_t {
+public:
+    explicit json_cursor_t(const std::string &s) : s_(s) {}
+    bool parse() {
+        ws();
+        if (!value()) return false;
+        ws();
+        return p_ == s_.size();
+    }
+
+private:
+    void ws() {
+        while (p_ < s_.size()
+                && (s_[p_] == ' ' || s_[p_] == '\t' || s_[p_] == '\r'
+                        || s_[p_] == '\n'))
+            ++p_;
+    }
+    bool literal(const char *x) {
+        const size_t n = std::strlen(x);
+        if (s_.compare(p_, n, x) != 0) return false;
+        p_ += n;
+        return true;
+    }
+    bool string() {
+        if (p_ == s_.size() || s_[p_++] != '"') return false;
+        while (p_ < s_.size()) {
+            const unsigned char c = s_[p_++];
+            if (c == '"') return true;
+            if (c < 0x20) return false;
+            if (c == '\\') {
+                if (p_ == s_.size()) return false;
+                const char e = s_[p_++];
+                if (e == 'u') {
+                    for (int i = 0; i < 4; ++i) {
+                        if (p_ == s_.size()
+                                || !std::isxdigit(
+                                        static_cast<unsigned char>(s_[p_++])))
+                            return false;
+                    }
+                } else if (std::string("\"\\/bfnrt").find(e)
+                        == std::string::npos)
+                    return false;
+            }
+        }
+        return false;
+    }
+    bool number() {
+        const size_t begin = p_;
+        if (p_ < s_.size() && s_[p_] == '-') ++p_;
+        if (p_ == s_.size()) return false;
+        if (s_[p_] == '0')
+            ++p_;
+        else {
+            if (!std::isdigit(static_cast<unsigned char>(s_[p_]))) return false;
+            while (p_ < s_.size()
+                    && std::isdigit(static_cast<unsigned char>(s_[p_])))
+                ++p_;
+        }
+        if (p_ < s_.size() && s_[p_] == '.') {
+            ++p_;
+            if (p_ == s_.size()
+                    || !std::isdigit(static_cast<unsigned char>(s_[p_])))
+                return false;
+            while (p_ < s_.size()
+                    && std::isdigit(static_cast<unsigned char>(s_[p_])))
+                ++p_;
+        }
+        if (p_ < s_.size() && (s_[p_] == 'e' || s_[p_] == 'E')) {
+            ++p_;
+            if (p_ < s_.size() && (s_[p_] == '+' || s_[p_] == '-')) ++p_;
+            if (p_ == s_.size()
+                    || !std::isdigit(static_cast<unsigned char>(s_[p_])))
+                return false;
+            while (p_ < s_.size()
+                    && std::isdigit(static_cast<unsigned char>(s_[p_])))
+                ++p_;
+        }
+        return p_ > begin;
+    }
+    bool array() {
+        ++p_;
+        ws();
+        if (p_ < s_.size() && s_[p_] == ']') {
+            ++p_;
+            return true;
+        }
+        while (value()) {
+            ws();
+            if (p_ < s_.size() && s_[p_] == ']') {
+                ++p_;
+                return true;
+            }
+            if (p_ == s_.size() || s_[p_++] != ',') return false;
+            ws();
+        }
+        return false;
+    }
+    bool object() {
+        ++p_;
+        ws();
+        if (p_ < s_.size() && s_[p_] == '}') {
+            ++p_;
+            return true;
+        }
+        while (string()) {
+            ws();
+            if (p_ == s_.size() || s_[p_++] != ':') return false;
+            ws();
+            if (!value()) return false;
+            ws();
+            if (p_ < s_.size() && s_[p_] == '}') {
+                ++p_;
+                return true;
+            }
+            if (p_ == s_.size() || s_[p_++] != ',') return false;
+            ws();
+        }
+        return false;
+    }
+    bool value() {
+        ws();
+        if (p_ == s_.size()) return false;
+        if (s_[p_] == '{') return object();
+        if (s_[p_] == '[') return array();
+        if (s_[p_] == '"') return string();
+        if (s_[p_] == '-' || std::isdigit(static_cast<unsigned char>(s_[p_])))
+            return number();
+        return literal("true") || literal("false") || literal("null");
+    }
+    const std::string &s_;
+    size_t p_ = 0;
+};
+
+bool valid_json(const std::string &s) {
+    return json_cursor_t(s).parse();
+}
+
+template <typename T>
+bool field_number(const std::string &s, const char *name, T &out) {
+    const std::string key = std::string("\"") + name + "\"";
+    size_t p = s.find(key);
+    if (p == std::string::npos) return false;
+    p += key.size();
+    while (p < s.size() && std::isspace(static_cast<unsigned char>(s[p])))
+        ++p;
+    if (p == s.size() || s[p++] != ':') return false;
+    while (p < s.size() && std::isspace(static_cast<unsigned char>(s[p])))
+        ++p;
+    std::istringstream is(s.substr(p));
+    is >> out;
+    return !is.fail();
+}
+
+bool field_string(const std::string &s, const char *name, std::string &out) {
+    const std::string key = std::string("\"") + name + "\"";
+    size_t p = s.find(key);
+    if (p == std::string::npos) return false;
+    p += key.size();
+    while (p < s.size() && std::isspace(static_cast<unsigned char>(s[p])))
+        ++p;
+    if (p == s.size() || s[p++] != ':') return false;
+    while (p < s.size() && std::isspace(static_cast<unsigned char>(s[p])))
+        ++p;
+    if (p == s.size() || s[p++] != '"') return false;
+    size_t e = s.find('"', p);
+    if (e == std::string::npos) return false;
+    out = s.substr(p, e - p);
+    return true;
+}
+
+template <typename T>
+void unique_push(std::vector<T> &v, T x) {
+    if (std::find(v.begin(), v.end(), x) == v.end()) v.push_back(x);
+}
+
+double tail_penalty(int64_t dim, int block) {
+    if (block <= 0 || dim <= block || dim % block == 0) return 0;
+    return 1.0 - static_cast<double>(dim % block) / block;
+}
+} // namespace
+
+uint64_t stable_hash(const std::string &s) {
+    uint64_t h = UINT64_C(1469598103934665603);
+    for (unsigned char c : s) {
+        h ^= c;
+        h *= UINT64_C(1099511628211);
+    }
+    return h;
+}
+
+std::string pack_a_name(pack_a_t v) {
+    return v == pack_a_t::direct ? "direct" : "per_call_padded";
+}
+std::string pack_b_name(pack_b_t v) {
+    switch (v) {
+        case pack_b_t::direct: return "direct";
+        case pack_b_t::per_call_n32: return "per_call_n32";
+        case pack_b_t::per_call_n64: return "per_call_n64";
+        case pack_b_t::persistent_n32: return "persistent_n32";
+        case pack_b_t::persistent_n64: return "persistent_n64";
+    }
+    return "invalid";
+}
+std::string loop_order_name(loop_order_t v) {
+    return v == loop_order_t::one_load ? "one-load" : "default";
+}
+
+std::string workload_key(const workload_t &w, const std::string &identity) {
+    std::ostringstream os;
+    os << "schema=" << w.version << ";M=" << w.M << ";N=" << w.N << ";K=" << w.K
+       << ";threads=" << w.threads << ";cpus=" << w.cpus
+       << ";alpha=1;beta=0;identity=" << identity;
+    std::ostringstream hex;
+    hex << std::hex << stable_hash(os.str());
+    return hex.str();
+}
+
+std::string plan_json(const plan_t &p) {
+    std::ostringstream os;
+    os << "{\"schema_version\":" << p.version << ",\"M_blk\":" << p.M_blk
+       << ",\"N_blk\":" << p.N_blk << ",\"K_blk\":" << p.K_blk
+       << ",\"M_chunk_size\":" << p.M_chunk_size
+       << ",\"N_chunk_size\":" << p.N_chunk_size
+       << ",\"K_chunk_size\":" << p.K_chunk_size
+       << ",\"brgemm_batch_size\":" << p.brgemm_batch_size
+       << ",\"nthr_k\":" << p.nthr_k << ",\"pack_a\":\""
+       << pack_a_name(p.pack_a) << "\",\"pack_b\":\"" << pack_b_name(p.pack_b)
+       << "\",\"bd_block\":" << p.bd_block << ",\"ld_block2\":" << p.ld_block2
+       << ",\"loop_order\":\"" << loop_order_name(p.loop_order) << "\"}";
+    return os.str();
+}
+
+bool parse_plan_json(const std::string &s, plan_t &p, std::string &error) {
+    unsigned version = 0;
+    std::string a, b, loop;
+    if (!valid_json(s)) {
+        error = "malformed JSON";
+        return false;
+    }
+    if (!field_number(s, "schema_version", version)
+            || !field_number(s, "M_blk", p.M_blk)
+            || !field_number(s, "N_blk", p.N_blk)
+            || !field_number(s, "K_blk", p.K_blk)
+            || !field_number(s, "M_chunk_size", p.M_chunk_size)
+            || !field_number(s, "N_chunk_size", p.N_chunk_size)
+            || !field_number(s, "K_chunk_size", p.K_chunk_size)
+            || !field_number(s, "brgemm_batch_size", p.brgemm_batch_size)
+            || !field_number(s, "nthr_k", p.nthr_k)
+            || !field_number(s, "bd_block", p.bd_block)
+            || !field_number(s, "ld_block2", p.ld_block2)
+            || !field_string(s, "pack_a", a) || !field_string(s, "pack_b", b)
+            || !field_string(s, "loop_order", loop)) {
+        error = "missing or malformed plan field";
+        return false;
+    }
+    p.version = version;
+    if (version != dnnl::impl::cpu::matopt::schema_version) {
+        error = "unsupported schema version";
+        return false;
+    }
+    if (a == "direct")
+        p.pack_a = pack_a_t::direct;
+    else if (a == "per_call_padded")
+        p.pack_a = pack_a_t::per_call_padded;
+    else {
+        error = "invalid pack_a";
+        return false;
+    }
+    if (b == "direct")
+        p.pack_b = pack_b_t::direct;
+    else if (b == "per_call_n32")
+        p.pack_b = pack_b_t::per_call_n32;
+    else if (b == "per_call_n64")
+        p.pack_b = pack_b_t::per_call_n64;
+    else if (b == "persistent_n32")
+        p.pack_b = pack_b_t::persistent_n32;
+    else if (b == "persistent_n64")
+        p.pack_b = pack_b_t::persistent_n64;
+    else {
+        error = "invalid pack_b";
+        return false;
+    }
+    if (loop == "default")
+        p.loop_order = loop_order_t::default_order;
+    else if (loop == "one-load")
+        p.loop_order = loop_order_t::one_load;
+    else {
+        error = "invalid loop_order";
+        return false;
+    }
+    return true;
+}
+
+std::string finalized_json(const finalized_plan_t &p) {
+    std::ostringstream os;
+    os << "{\"plan\":" << plan_json(p) << ",\"M\":" << p.M << ",\"N\":" << p.N
+       << ",\"K\":" << p.K << ",\"M_tail\":" << p.M_tail
+       << ",\"N_tail\":" << p.N_tail << ",\"K_tail\":" << p.K_tail
+       << ",\"LDA\":" << p.LDA << ",\"LDB\":" << p.LDB << ",\"LDC\":" << p.LDC
+       << ",\"M_chunks\":" << p.M_chunks << ",\"N_chunks\":" << p.N_chunks
+       << ",\"K_chunks\":" << p.K_chunks
+       << ",\"realized_bd_block\":" << p.realized_bd_block
+       << ",\"realized_ld_block2\":" << p.realized_ld_block2
+       << ",\"use_buffer_a\":" << (p.use_buffer_a ? "true" : "false")
+       << ",\"use_buffer_b\":" << (p.use_buffer_b ? "true" : "false")
+       << ",\"blocked_B\":" << (p.blocked_B ? "true" : "false")
+       << ",\"scratchpad_bytes\":" << p.scratchpad_bytes << "}";
+    return os.str();
+}
+
+std::string measurement_json(const measurement_t &m) {
+    std::ostringstream os;
+    os << std::setprecision(9) << "{\"one_shot_ms\":" << m.one_shot_ms
+       << ",\"steady_ms\":" << m.steady_ms
+       << ",\"throughput_gflops\":" << m.throughput_gflops
+       << ",\"median_ms\":" << m.median_ms << ",\"minimum_ms\":" << m.minimum_ms
+       << ",\"p90_ms\":" << m.p90_ms << ",\"packing_ms\":" << m.packing_ms
+       << ",\"packed_bytes\":" << m.packed_bytes
+       << ",\"packed_gbps\":" << m.packed_gbps
+       << ",\"compute_ms\":" << m.compute_ms
+       << ",\"scratchpad_bytes\":" << m.scratchpad_bytes
+       << ",\"correct\":" << (m.correct ? "true" : "false")
+       << ",\"stable\":" << (m.stable ? "true" : "false") << "}";
+    return os.str();
+}
+
+size_t estimate_scratchpad(const plan_t &p) {
+    size_t bytes = 0;
+    if (p.pack_a == pack_a_t::per_call_padded)
+        bytes += static_cast<size_t>(p.M_blk) * p.K_blk * 4;
+    if (p.pack_b == pack_b_t::per_call_n32
+            || p.pack_b == pack_b_t::per_call_n64)
+        bytes += static_cast<size_t>(p.K_blk) * p.N_blk * p.brgemm_batch_size
+                * 4;
+    if (p.nthr_k > 1) bytes += static_cast<size_t>(p.M_blk) * p.N_blk * 4;
+    return bytes;
+}
+
+std::string validate_plan(
+        const workload_t &w, const plan_t &p, size_t scratch_limit) {
+    if (w.version != 1 || w.M <= 0 || w.N <= 0 || w.K <= 0 || w.threads <= 0)
+        return "invalid workload";
+    if (w.alpha != 1.f || w.beta != 0.f) return "MVP requires alpha=1,beta=0";
+    if (p.M_blk <= 0 || p.N_blk <= 0 || p.K_blk <= 0 || p.M_chunk_size <= 0
+            || p.N_chunk_size <= 0 || p.brgemm_batch_size <= 0 || p.nthr_k <= 0)
+        return "non-positive blocking field";
+    if (p.M_blk > w.M || p.N_blk > w.N || p.K_blk > w.K)
+        return "block exceeds workload dimension";
+    if (!w.allow_split_k && p.nthr_k != 1)
+        return "split-K tuning is disabled on AArch64";
+    if (w.threads % p.nthr_k) return "nthr_k is not a thread-count divisor";
+    const int64_t k_blocks = (w.K + p.K_blk - 1) / p.K_blk;
+    if (p.brgemm_batch_size > k_blocks)
+        return "BRGEMM batch size exceeds the number of K blocks";
+    const int64_t k_chunks
+            = (k_blocks + p.brgemm_batch_size - 1) / p.brgemm_batch_size;
+    if (p.nthr_k > k_chunks) return "nthr_k exceeds the number of K chunks";
+    const bool n32 = p.pack_b == pack_b_t::per_call_n32
+            || p.pack_b == pack_b_t::persistent_n32;
+    const bool n64 = p.pack_b == pack_b_t::per_call_n64
+            || p.pack_b == pack_b_t::persistent_n64;
+    if ((n32 && p.N_blk != 32) || (n64 && p.N_blk != 64))
+        return "B format is incompatible with N_blk";
+    if (p.bd_block < 0 || p.bd_block > 7 || p.ld_block2 < 0 || p.ld_block2 > 4)
+        return "invalid microtile hint";
+    if (p.bd_block && p.ld_block2 && p.bd_block * p.ld_block2 > 28)
+        return "microtile exceeds register-pressure budget";
+    if (estimate_scratchpad(p) > scratch_limit)
+        return "estimated scratchpad exceeds 64 MiB per thread";
+    return "";
+}
+
+std::vector<candidate_t> generate_candidates(
+        const workload_t &w, const finalized_plan_t &b, size_t cap) {
+    std::vector<int> ms {b.M_blk, 64, 96, 128, 160, 192, 224, 256};
+    std::vector<int> ns {b.N_blk, 32, 64};
+    std::vector<int> ks {b.K_blk, 256, 512, 1024};
+    std::vector<int> ncs {b.N_chunk_size, 1, 2, 4, 8};
+    std::vector<int> batches {b.brgemm_batch_size, 1, 2, 4};
+    std::vector<int> nthrks = w.allow_split_k
+            ? std::vector<int> {b.nthr_k, 1, 2, 4}
+            : std::vector<int> {1};
+    std::vector<pack_a_t> as {pack_a_t::direct, pack_a_t::per_call_padded};
+    std::vector<pack_b_t> bs {pack_b_t::direct, pack_b_t::per_call_n32,
+            pack_b_t::per_call_n64, pack_b_t::persistent_n32,
+            pack_b_t::persistent_n64};
+    std::vector<candidate_t> out;
+    std::set<uint64_t> seen;
+    for (int m : ms)
+        for (int n : ns)
+            for (int k : ks)
+                for (int nc : ncs)
+                    for (int batch : batches)
+                        for (int nk : nthrks)
+                            for (pack_a_t a : as)
+                                for (pack_b_t pb : bs) {
+                                    plan_t p = b;
+                                    p.M_blk = m;
+                                    p.N_blk = n;
+                                    p.K_blk = k;
+                                    p.N_chunk_size = nc;
+                                    p.brgemm_batch_size = batch;
+                                    p.nthr_k = nk;
+                                    p.pack_a = a;
+                                    p.pack_b = pb;
+                                    p.bd_block = 0;
+                                    p.ld_block2 = 0;
+                                    p.loop_order = loop_order_t::default_order;
+                                    const uint64_t h
+                                            = stable_hash(plan_json(p));
+                                    if (!seen.insert(h).second) continue;
+                                    candidate_t c;
+                                    c.plan = p;
+                                    c.hash = h;
+                                    c.rejection = validate_plan(w, p);
+                                    const double distance = (m != b.M_blk)
+                                            + (n != b.N_blk) + (k != b.K_blk)
+                                            + (nc != b.N_chunk_size)
+                                            + (batch != b.brgemm_batch_size)
+                                            + (nk != b.nthr_k) + (a != b.pack_a)
+                                            + (pb != b.pack_b);
+                                    c.rank = distance * 1000.0
+                                            + estimate_scratchpad(p) / 65536.0
+                                            + 100.0
+                                                    * (tail_penalty(w.M, m)
+                                                            + tail_penalty(
+                                                                    w.N, n)
+                                                            + tail_penalty(
+                                                                    w.K, k))
+                                            + static_cast<double>(h & 0xffff)
+                                                    / 65536.0;
+                                    // Preserve baseline and every one-field mutation. More distant
+                                    // Cartesian points must provide useful parallel work and avoid gross
+                                    // padding waste before entering the capped ranking set.
+                                    if (c.rejection.empty() && distance > 1.0) {
+                                        const int64_t m_units
+                                                = (w.M + p.M_blk * p.M_chunk_size
+                                                          - 1)
+                                                / (p.M_blk * p.M_chunk_size);
+                                        const int64_t n_units
+                                                = (w.N + p.N_blk * p.N_chunk_size
+                                                          - 1)
+                                                / (p.N_blk * p.N_chunk_size);
+                                        const int64_t parallel_work
+                                                = m_units * n_units;
+                                        const int64_t k_blocks
+                                                = (w.K + p.K_blk - 1) / p.K_blk;
+                                        const int64_t k_chunks
+                                                = (k_blocks
+                                                          + p.brgemm_batch_size
+                                                          - 1)
+                                                / p.brgemm_batch_size;
+                                        if (parallel_work
+                                                        * std::min<int64_t>(
+                                                                p.nthr_k,
+                                                                k_chunks)
+                                                        * 2
+                                                < w.threads)
+                                            c.rejection
+                                                    = "insufficient parallel "
+                                                      "work";
+                                        const double severe_tail
+                                                = tail_penalty(w.M, p.M_blk)
+                                                + tail_penalty(w.N, p.N_blk)
+                                                + tail_penalty(w.K, p.K_blk);
+                                        if (c.rejection.empty()
+                                                && severe_tail > 2.25)
+                                            c.rejection
+                                                    = "severe aggregate tail "
+                                                      "waste";
+                                    }
+                                    if (c.rejection.empty()) out.push_back(c);
+                                }
+    std::sort(out.begin(), out.end(),
+            [](const candidate_t &a, const candidate_t &b) {
+        if (a.rank != b.rank) return a.rank < b.rank;
+        return a.hash < b.hash;
+    });
+    if (out.size() > cap) out.resize(cap);
+    return out;
+}
+
+std::vector<size_t> pareto_indices(const std::vector<candidate_t> &cs) {
+    std::vector<size_t> result;
+    for (size_t i = 0; i < cs.size(); ++i) {
+        const auto &a = cs[i].measurement;
+        if (!a.correct || !a.stable) continue;
+        bool dominated = false;
+        for (size_t j = 0; j < cs.size() && !dominated; ++j) {
+            if (i == j) continue;
+            const auto &b = cs[j].measurement;
+            if (!b.correct || !b.stable) continue;
+            const bool no_worse = b.one_shot_ms <= a.one_shot_ms
+                    && b.steady_ms <= a.steady_ms
+                    && b.throughput_gflops >= a.throughput_gflops
+                    && b.scratchpad_bytes <= a.scratchpad_bytes;
+            const bool better = b.one_shot_ms < a.one_shot_ms
+                    || b.steady_ms < a.steady_ms
+                    || b.throughput_gflops > a.throughput_gflops
+                    || b.scratchpad_bytes < a.scratchpad_bytes;
+            dominated = no_worse && better;
+        }
+        if (!dominated) result.push_back(i);
+    }
+    return result;
+}
+
+size_t choose_candidate(const std::vector<candidate_t> &cs, unsigned objective,
+        size_t baseline, double noise) {
+    size_t best = baseline;
+    for (size_t i = 0; i < cs.size(); ++i) {
+        if (!cs[i].measurement.correct || !cs[i].measurement.stable) continue;
+        if (objective == one_shot
+                && cs[i].measurement.one_shot_ms
+                        < cs[best].measurement.one_shot_ms)
+            best = i;
+        if (objective == steady
+                && cs[i].measurement.steady_ms < cs[best].measurement.steady_ms)
+            best = i;
+        if (objective == throughput
+                && cs[i].measurement.throughput_gflops
+                        > cs[best].measurement.throughput_gflops)
+            best = i;
+    }
+    double gain = 0;
+    if (objective == throughput)
+        gain = cs[best].measurement.throughput_gflops
+                        / cs[baseline].measurement.throughput_gflops
+                - 1.0;
+    else {
+        const double bv = objective == one_shot
+                ? cs[baseline].measurement.one_shot_ms
+                : cs[baseline].measurement.steady_ms;
+        const double cv = objective == one_shot
+                ? cs[best].measurement.one_shot_ms
+                : cs[best].measurement.steady_ms;
+        gain = 1.0 - cv / bv;
+    }
+    return gain > std::max(0.01, noise) ? best : baseline;
+}
+
+bool validate_history(const std::string &path, const std::string &key,
+        size_t &records, std::string &error) {
+    records = 0;
+    std::ifstream f(path.c_str(), std::ios::binary);
+    if (!f) return true;
+    std::string all((std::istreambuf_iterator<char>(f)), {});
+    size_t pos = 0;
+    while (pos < all.size()) {
+        size_t end = all.find('\n', pos);
+        const bool final_unterminated = end == std::string::npos;
+        if (final_unterminated) end = all.size();
+        const std::string line = all.substr(pos, end - pos);
+        if (!line.empty()) {
+            const bool object = valid_json(line);
+            std::string found;
+            const bool has_key = field_string(line, "resume_key", found);
+            if (!object || !has_key) {
+                if (final_unterminated) return true;
+                error = "malformed complete JSONL record "
+                        + std::to_string(records + 1);
+                return false;
+            }
+            if (found != key) {
+                error = "history resume key mismatch";
+                return false;
+            }
+            ++records;
+        }
+        if (final_unterminated) break;
+        pos = end + 1;
+    }
+    return true;
+}
+
+} // namespace matopt_tool
