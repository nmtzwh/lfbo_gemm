+/*******************************************************************************
+* Copyright 2026
+* Licensed under the Apache License, Version 2.0 (the "License");
+******************************************************************************/
+#include "matopt_core.hpp"
+
+#include <cmath>
+#include <cstring>
+#include <iostream>
+#include <vector>
+#include <unordered_map>
+
+#include "oneapi/dnnl/dnnl.hpp"
+
+using namespace dnnl;
+using namespace matopt_tool;
+using dnnl::impl::cpu::matopt::clear_capture;
+using dnnl::impl::cpu::matopt::get_capture;
+using dnnl::impl::cpu::matopt::scoped_plan_t;
+
+namespace {
+constexpr int64_t M = 130, N = 70, K = 66;
+
+struct fixture_t {
+    engine eng {engine::kind::cpu, 0};
+    stream strm {eng};
+    memory::desc a_md {{M, K}, memory::data_type::f32, memory::format_tag::ab};
+    memory::desc b_md {{K, N}, memory::data_type::f32, memory::format_tag::ab};
+    memory::desc c_md {{M, N}, memory::data_type::f32, memory::format_tag::ab};
+    std::vector<float> A = std::vector<float>(M * K);
+    std::vector<float> B = std::vector<float>(K * N);
+    std::vector<float> reference = std::vector<float>(M * N);
+
+    fixture_t() {
+        for (size_t i = 0; i < A.size(); ++i)
+            A[i] = static_cast<int>(i % 7) - 3;
+        for (size_t i = 0; i < B.size(); ++i)
+            B[i] = static_cast<int>(i % 5) - 2;
+        A[17] += 0.125f;
+        B[23] -= 0.25f;
+        memory a(a_md, eng, A.data()), b(b_md, eng, B.data()), c(c_md, eng);
+        matmul::primitive_desc pd(eng, a_md, b_md, c_md);
+        matmul(pd).execute(strm,
+                {{DNNL_ARG_SRC, a}, {DNNL_ARG_WEIGHTS, b}, {DNNL_ARG_DST, c}});
+        strm.wait();
+        std::memcpy(
+                reference.data(), c.get_data_handle(), reference.size() * 4);
+    }
+
+    bool run(const plan_t &plan, finalized_plan_t &finalized) {
+        const bool persistent = plan.pack_b == pack_b_t::persistent_n32
+                || plan.pack_b == pack_b_t::persistent_n64;
+        clear_capture();
+        scoped_plan_t scope(&plan);
+        auto requested_b = persistent
+                ? memory::desc({K, N}, memory::data_type::f32,
+                          memory::format_tag::any)
+                : b_md;
+        matmul::primitive_desc pd(eng, a_md, requested_b, c_md);
+        matmul primitive(pd);
+        if (!get_capture(finalized) || finalized.realized_bd_block == 0)
+            return false;
+        memory a(a_md, eng, A.data()), plain_b(b_md, eng, B.data());
+        memory exec_b = persistent ? memory(pd.weights_desc(), eng) : plain_b;
+        if (persistent) {
+            reorder(plain_b, exec_b).execute(strm, plain_b, exec_b);
+            strm.wait();
+        }
+        memory c(c_md, eng);
+        primitive.execute(strm,
+                {{DNNL_ARG_SRC, a}, {DNNL_ARG_WEIGHTS, exec_b},
+                        {DNNL_ARG_DST, c}});
+        strm.wait();
+        const float *got = static_cast<const float *>(c.get_data_handle());
+        for (size_t i = 0; i < reference.size(); ++i) {
+            const float tol = 2e-4f * std::max(1.f, std::fabs(reference[i]));
+            if (std::fabs(got[i] - reference[i]) > tol) return false;
+        }
+        return true;
+    }
+};
+
+plan_t plan(pack_a_t a, pack_b_t b) {
+    plan_t p;
+    p.M_blk = 64;
+    p.N_blk = (b == pack_b_t::per_call_n32 || b == pack_b_t::persistent_n32)
+            ? 32
+            : 64;
+    p.K_blk = 64;
+    p.M_chunk_size = p.N_chunk_size = p.K_chunk_size = 1;
+    p.brgemm_batch_size = 1;
+    p.nthr_k = 1;
+    p.pack_a = a;
+    p.pack_b = b;
+    return p;
+}
+} // namespace
+
+int main() {
+    dnnl::set_primitive_cache_capacity(0);
+    fixture_t f;
+    const std::vector<std::pair<pack_a_t, pack_b_t>> policies {
+            {pack_a_t::direct, pack_b_t::direct},
+            {pack_a_t::per_call_padded, pack_b_t::direct},
+            {pack_a_t::direct, pack_b_t::per_call_n32},
+            {pack_a_t::direct, pack_b_t::per_call_n64},
+            {pack_a_t::direct, pack_b_t::persistent_n32},
+            {pack_a_t::direct, pack_b_t::persistent_n64}};
+    for (const auto &policy : policies) {
+        finalized_plan_t out;
+        const auto p = plan(policy.first, policy.second);
+        try {
+            if (!f.run(p, out)) {
+                std::cerr << "packing policy failed: "
+                          << pack_a_name(policy.first) << '/'
+                          << pack_b_name(policy.second) << '\n';
+                return 1;
+            }
+        } catch (const std::exception &e) {
+            std::cerr << "packing policy threw: " << pack_a_name(policy.first)
+                      << '/' << pack_b_name(policy.second) << ": " << e.what()
+                      << '\n';
+            return 1;
+        }
+        if (out.M_tail != 2 || out.N_tail != N % p.N_blk || out.K_tail != 2) {
+            std::cerr << "combined tail finalization mismatch\n";
+            return 1;
+        }
+    }
+    auto hinted = plan(pack_a_t::direct, pack_b_t::direct);
+    hinted.bd_block = 4;
+    hinted.ld_block2 = 2;
+    finalized_plan_t realized;
+    if (!f.run(hinted, realized) || realized.realized_bd_block != 4
+            || realized.realized_ld_block2 != 2) {
+        std::cerr << "microtile hint was not realized\n";
+        return 1;
+    }
+    std::cout << "matopt backend tests passed\n";
+    return 0;
+}
diff --git a/tools/matopt/test_matopt.cpp b/tools/matopt/test_matopt.cpp
new file mode 100644
index 0000000000000000000000000000000000000000..70b5dba06450f28e66690d982f0aa931eb8a4453
--- /dev/null
+++ b/tools/matopt/test_matopt.cpp
@@ -0,0 +1,153 @@
+/*******************************************************************************
+* Copyright 2026
+* Licensed under the Apache License, Version 2.0 (the "License");
+******************************************************************************/
+#include "matopt_core.hpp"
+
+#include "cpu/matmul/matopt_copy_a.hpp"
+
+#include <cstdio>
+#include <fstream>
+#include <iostream>
+
+using namespace matopt_tool;
+namespace {
+int failures = 0;
+#define CHECK(x) \
+    do { \
+        if (!(x)) { \
+            std::cerr << __FILE__ << ':' << __LINE__ \
+                      << ": CHECK(" #x ") failed\n"; \
+            ++failures; \
+        } \
+    } while (0)
+
+plan_t sample_plan() {
+    plan_t p;
+    p.M_blk = 128;
+    p.N_blk = 64;
+    p.K_blk = 512;
+    p.M_chunk_size = 1;
+    p.N_chunk_size = 2;
+    p.K_chunk_size = 1;
+    p.brgemm_batch_size = 2;
+    p.nthr_k = 1;
+    p.pack_a = pack_a_t::per_call_padded;
+    p.pack_b = pack_b_t::per_call_n64;
+    p.bd_block = 6;
+    p.ld_block2 = 4;
+    p.loop_order = loop_order_t::one_load;
+    return p;
+}
+} // namespace
+
+int main() {
+    plan_t p = sample_plan(), q;
+    std::string error;
+    CHECK(parse_plan_json(plan_json(p), q, error));
+    CHECK(plan_json(p) == plan_json(q));
+    CHECK(stable_hash(plan_json(p)) == stable_hash(plan_json(q)));
+
+    const float copy_src[] {1, 2, 3, 99, 4, 5, 6, 99};
+    float copy_dst[10];
+    for (float &v : copy_dst)
+        v = -1;
+    dnnl::impl::cpu::matopt::copy_a_f32(
+            copy_src, copy_dst, 2, 3, 4 * sizeof(float), 5);
+    CHECK(copy_dst[0] == 1 && copy_dst[1] == 2 && copy_dst[2] == 3);
+    CHECK(copy_dst[3] == 0 && copy_dst[4] == 0);
+    CHECK(copy_dst[5] == 4 && copy_dst[6] == 5 && copy_dst[7] == 6);
+    CHECK(copy_dst[8] == 0 && copy_dst[9] == 0);
+
+    workload_t w;
+    w.M = 4096;
+    w.N = 4096;
+    w.K = 4096;
+    w.threads = 8;
+    CHECK(validate_plan(w, p).empty());
+    q = p;
+    q.N_blk = 32;
+    CHECK(validate_plan(w, q) == "B format is incompatible with N_blk");
+    q = p;
+    q.nthr_k = 3;
+    CHECK(validate_plan(w, q) == "nthr_k is not a thread-count divisor");
+    w.allow_split_k = false;
+    q.nthr_k = 2;
+    CHECK(validate_plan(w, q) == "split-K tuning is disabled on AArch64");
+    w.allow_split_k = true;
+    q = p;
+    q.nthr_k = 4;
+    q.brgemm_batch_size = 4;
+    CHECK(validate_plan(w, q) == "nthr_k exceeds the number of K chunks");
+    q = p;
+    q.brgemm_batch_size = 9;
+    CHECK(validate_plan(w, q)
+            == "BRGEMM batch size exceeds the number of K blocks");
+    q = p;
+    q.bd_block = 7;
+    q.ld_block2 = 4;
+    CHECK(validate_plan(w, q).empty());
+    q.bd_block = 8;
+    CHECK(validate_plan(w, q) == "invalid microtile hint");
+
+    finalized_plan_t base;
+    static_cast<plan_t &>(base) = p;
+    base.M_blk = 128;
+    base.N_blk = 64;
+    base.K_blk = 512;
+    auto candidates = generate_candidates(w, base);
+    CHECK(!candidates.empty());
+    CHECK(candidates.size() <= 256);
+    for (const auto &c : candidates)
+        CHECK(validate_plan(w, c.plan).empty());
+
+    w.allow_split_k = false;
+    candidates = generate_candidates(w, base);
+    CHECK(!candidates.empty());
+    for (const auto &c : candidates)
+        CHECK(c.plan.nthr_k == 1);
+
+    std::vector<candidate_t> cs(3);
+    for (auto &c : cs) {
+        c.measurement.correct = true;
+        c.measurement.stable = true;
+    }
+    cs[0].measurement.one_shot_ms = 10;
+    cs[0].measurement.steady_ms = 9;
+    cs[0].measurement.throughput_gflops = 100;
+    cs[0].measurement.scratchpad_bytes = 10;
+    cs[1].measurement.one_shot_ms = 9;
+    cs[1].measurement.steady_ms = 8;
+    cs[1].measurement.throughput_gflops = 110;
+    cs[1].measurement.scratchpad_bytes = 9;
+    cs[2].measurement.one_shot_ms = 8;
+    cs[2].measurement.steady_ms = 10;
+    cs[2].measurement.throughput_gflops = 90;
+    cs[2].measurement.scratchpad_bytes = 8;
+    auto pareto = pareto_indices(cs);
+    CHECK(pareto.size() == 2);
+    CHECK(choose_candidate(cs, one_shot, 0, 0.0) == 2);
+    cs[1].measurement.one_shot_ms = 9.95;
+    CHECK(choose_candidate(cs, one_shot, 0, 0.02) == 2);
+
+    const std::string path = "/tmp/matopt_history_test.jsonl";
+    {
+        std::ofstream f(path.c_str());
+        f << "{\"resume_key\":\"abc\",\"state\":\"ok\"}\n";
+        f << "{truncated";
+    }
+    size_t records = 0;
+    CHECK(validate_history(path, "abc", records, error));
+    CHECK(records == 1);
+    {
+        std::ofstream f(path.c_str(), std::ios::app);
+        f << "}\n";
+    }
+    error.clear();
+    CHECK(!validate_history(path, "abc", records, error));
+    std::remove(path.c_str());
+
+    if (failures) return 1;
+    std::cout << "matopt unit tests passed\n";
+    return 0;
+}
