diff --git a/src/cpu/matmul/matopt_backend.cpp b/src/cpu/matmul/matopt_backend.cpp
new file mode 100644
index 0000000000000000000000000000000000000000..2283305ab2b4c0fc6815a38bfde1f741c3832382
--- /dev/null
+++ b/src/cpu/matmul/matopt_backend.cpp
@@ -0,0 +1,64 @@
+/*******************************************************************************
+* Copyright 2026
+*
+* Licensed under the Apache License, Version 2.0 (the "License");
+******************************************************************************/
+
+#include "cpu/matmul/matopt_backend.hpp"
+
+namespace dnnl {
+namespace impl {
+namespace cpu {
+namespace matopt {
+
+namespace {
+thread_local const plan_t *current_plan = nullptr;
+thread_local finalized_plan_t captured;
+thread_local bool captured_valid = false;
+thread_local std::string last_error;
+} // namespace
+
+scoped_plan_t::scoped_plan_t(const plan_t *plan) : previous_(current_plan) {
+    current_plan = plan;
+    last_error.clear();
+}
+
+scoped_plan_t::~scoped_plan_t() {
+    current_plan = previous_;
+}
+
+const plan_t *active_plan() {
+    return current_plan;
+}
+void clear_capture() {
+    captured = finalized_plan_t();
+    captured_valid = false;
+    last_error.clear();
+}
+bool get_capture(finalized_plan_t &out) {
+    if (!captured_valid) return false;
+    out = captured;
+    return true;
+}
+void set_error(const std::string &message) {
+    last_error = message;
+}
+std::string get_error() {
+    return last_error;
+}
+void publish_capture(const finalized_plan_t &value) {
+    captured = value;
+    captured_valid = true;
+}
+void capture_microtile(int bd_block, int ld_block2, size_t scratchpad_bytes) {
+    if (!captured_valid) return;
+    captured.realized_bd_block = bd_block;
+    captured.realized_ld_block2 = ld_block2;
+    if (scratchpad_bytes > captured.scratchpad_bytes)
+        captured.scratchpad_bytes = scratchpad_bytes;
+}
+
+} // namespace matopt
+} // namespace cpu
+} // namespace impl
+} // namespace dnnl
diff --git a/src/cpu/matmul/matopt_backend.hpp b/src/cpu/matmul/matopt_backend.hpp
new file mode 100644
index 0000000000000000000000000000000000000000..d2fa81e4fa675a2fe093ffe9bec351f1ab22d64f
--- /dev/null
+++ b/src/cpu/matmul/matopt_backend.hpp
@@ -0,0 +1,203 @@
+/*******************************************************************************
+* Copyright 2026
+*
+* Licensed under the Apache License, Version 2.0 (the "License");
+******************************************************************************/
+
+#ifndef CPU_MATMUL_MATOPT_BACKEND_HPP
+#define CPU_MATMUL_MATOPT_BACKEND_HPP
+
+#include <cstdint>
+#include <string>
+
+#include "common/c_types_map.hpp"
+
+namespace dnnl {
+namespace impl {
+namespace cpu {
+namespace matopt {
+
+constexpr uint32_t schema_version = 1;
+
+enum class pack_a_t { direct, per_call_padded };
+enum class pack_b_t {
+    direct,
+    per_call_n32,
+    per_call_n64,
+    persistent_n32,
+    persistent_n64
+};
+enum class loop_order_t { default_order, one_load };
+
+struct plan_t {
+    uint32_t version = schema_version;
+    int M_blk = 0;
+    int N_blk = 0;
+    int K_blk = 0;
+    int M_chunk_size = 0;
+    int N_chunk_size = 0;
+    int K_chunk_size = 0;
+    int brgemm_batch_size = 0;
+    int nthr_k = 0;
+    pack_a_t pack_a = pack_a_t::direct;
+    pack_b_t pack_b = pack_b_t::direct;
+    int bd_block = 0;
+    int ld_block2 = 0;
+    loop_order_t loop_order = loop_order_t::default_order;
+};
+
+struct finalized_plan_t : public plan_t {
+    int64_t M = 0, N = 0, K = 0;
+    int64_t M_tail = 0, N_tail = 0, K_tail = 0;
+    int64_t LDA = 0, LDB = 0, LDC = 0;
+    int M_chunks = 0, N_chunks = 0, K_chunks = 0;
+    int realized_bd_block = 0;
+    int realized_ld_block2 = 0;
+    bool use_buffer_a = false;
+    bool use_buffer_b = false;
+    bool blocked_B = false;
+    size_t scratchpad_bytes = 0;
+};
+
+class scoped_plan_t {
+public:
+    explicit scoped_plan_t(const plan_t *plan);
+    ~scoped_plan_t();
+    scoped_plan_t(const scoped_plan_t &) = delete;
+    scoped_plan_t &operator=(const scoped_plan_t &) = delete;
+
+private:
+    const plan_t *previous_;
+};
+
+const plan_t *active_plan();
+void clear_capture();
+bool get_capture(finalized_plan_t &out);
+void set_error(const std::string &message);
+std::string get_error();
+
+template <typename conf_t>
+status_t apply_plan(conf_t &c, bool allow_split_k = true) {
+    const plan_t *p = active_plan();
+    if (!p) return status::success;
+    if (p->version != schema_version) {
+        set_error("unsupported plan schema version");
+        return status::invalid_arguments;
+    }
+    if (p->M_blk <= 0 || p->N_blk <= 0 || p->K_blk <= 0 || p->M_chunk_size <= 0
+            || p->N_chunk_size <= 0 || p->brgemm_batch_size <= 0
+            || p->nthr_k <= 0) {
+        set_error("blocking and chunk fields must be positive");
+        return status::invalid_arguments;
+    }
+    if (!allow_split_k && p->nthr_k != 1) {
+        set_error("split-K tuning is disabled on AArch64");
+        return status::invalid_arguments;
+    }
+    if (p->K_blk % c.required_k_granularity != 0) {
+        set_error("K_blk violates the backend K granularity");
+        return status::invalid_arguments;
+    }
+    if (c.nthr % p->nthr_k != 0) {
+        set_error("nthr_k must divide the requested thread count");
+        return status::invalid_arguments;
+    }
+    const int64_t k_blocks
+            = (c.K + p->K_blk - 1) / static_cast<int64_t>(p->K_blk);
+    if (p->brgemm_batch_size > k_blocks) {
+        set_error("BRGEMM batch size exceeds the number of K blocks");
+        return status::invalid_arguments;
+    }
+    const int64_t k_chunks
+            = (k_blocks + p->brgemm_batch_size - 1) / p->brgemm_batch_size;
+    if (p->nthr_k > k_chunks) {
+        set_error("nthr_k exceeds the number of K chunks");
+        return status::invalid_arguments;
+    }
+    if (p->M_blk > c.M || p->N_blk > c.N || p->K_blk > c.K) {
+        set_error("macro block exceeds its workload dimension");
+        return status::invalid_arguments;
+    }
+    if (p->pack_a == pack_a_t::direct && c.transposed_A) {
+        set_error("direct A is incompatible with a transposed source");
+        return status::invalid_arguments;
+    }
+    const bool persistent = p->pack_b == pack_b_t::persistent_n32
+            || p->pack_b == pack_b_t::persistent_n64;
+    if (persistent && !c.blocked_B) {
+        set_error("persistent B requires a blocked weights descriptor");
+        return status::invalid_arguments;
+    }
+
+    c.M_blk = p->M_blk;
+    c.N_blk = p->N_blk;
+    c.K_blk = p->K_blk;
+    c.M_chunk_size = p->M_chunk_size;
+    c.N_chunk_size = p->N_chunk_size;
+    c.brgemm_batch_size = p->brgemm_batch_size;
+    c.nthr_k = p->nthr_k;
+    c.use_buffer_a = p->pack_a == pack_a_t::per_call_padded;
+    c.use_buffer_b = p->pack_b == pack_b_t::per_call_n32
+            || p->pack_b == pack_b_t::per_call_n64;
+    const bool n32 = p->pack_b == pack_b_t::per_call_n32
+            || p->pack_b == pack_b_t::persistent_n32;
+    const bool n64 = p->pack_b == pack_b_t::per_call_n64
+            || p->pack_b == pack_b_t::persistent_n64;
+    if ((n32 && p->N_blk != 32) || (n64 && p->N_blk != 64)) {
+        set_error("B packing policy and N_blk disagree");
+        return status::invalid_arguments;
+    }
+
+    const int64_t k_chunk_elems
+            = static_cast<int64_t>(c.K_blk) * c.brgemm_batch_size;
+    c.use_buffer_c = c.nthr_k > 1 && c.K > k_chunk_elems;
+    if (c.use_buffer_a) {
+        const int64_t elems = 64 / c.tr_a_dt_sz;
+        c.LDA = ((c.K_blk + elems - 1) / elems) * elems;
+        if (c.LDA >= 512 && (c.LDA & (c.LDA - 1)) == 0) c.LDA += elems;
+    } else {
+        c.LDA = c.A_strides[1] / c.a_dt_sz;
+    }
+    return status::success;
+}
+
+template <typename conf_t>
+void capture(const conf_t &c) {
+    finalized_plan_t f;
+    const plan_t *p = active_plan();
+    if (p) static_cast<plan_t &>(f) = *p;
+    f.M = c.M;
+    f.N = c.N;
+    f.K = c.K;
+    f.M_blk = static_cast<int>(c.M_blk);
+    f.N_blk = static_cast<int>(c.N_blk);
+    f.K_blk = static_cast<int>(c.K_blk);
+    f.M_chunk_size = c.M_chunk_size;
+    f.N_chunk_size = c.N_chunk_size;
+    f.K_chunk_size = 1;
+    f.brgemm_batch_size = c.brgemm_batch_size;
