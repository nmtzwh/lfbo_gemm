+++ b/tools/matopt/main.cpp
@@ -0,0 +1,1071 @@
+/*******************************************************************************
+* Copyright 2026
+* Licensed under the Apache License, Version 2.0 (the "License");
+******************************************************************************/
+#include "matopt_core.hpp"
+
+#include <algorithm>
+#include <cctype>
+#include <chrono>
+#include <cmath>
+#include <cstdio>
+#include <cstring>
+#include <fstream>
+#include <iostream>
+#include <map>
+#include <numeric>
+#include <set>
+#include <sstream>
+#include <stdexcept>
+#include <vector>
+#include <unordered_map>
+
+#include <omp.h>
+#include <sched.h>
+#include <unistd.h>
+
+#include "oneapi/dnnl/dnnl.hpp"
+#include "oneapi/dnnl/dnnl_debug.h"
+
+using namespace dnnl;
+using namespace matopt_tool;
+using backend = dnnl::impl::cpu::matopt::scoped_plan_t;
+
+namespace {
+using clock_t = std::chrono::steady_clock;
+
+struct options_t {
+    std::string command;
+    std::map<std::string, std::string> values;
+    bool has(const std::string &k) const { return values.count(k) != 0; }
+    std::string get(const std::string &k, const std::string &d = "") const {
+        auto i = values.find(k);
+        return i == values.end() ? d : i->second;
+    }
+};
+
+options_t parse_args(int argc, char **argv) {
+    if (argc < 2)
+        throw std::runtime_error("expected tune, benchmark, or inspect");
+    options_t o;
+    o.command = argv[1];
+    for (int i = 2; i < argc; ++i) {
+        std::string k = argv[i];
+        if (k.compare(0, 2, "--") != 0)
+            throw std::runtime_error("unexpected argument: " + k);
+        k.erase(0, 2);
+        if (k == "compare-default") {
+            o.values[k] = "true";
+            continue;
+        }
+        if (++i == argc) throw std::runtime_error("missing value for --" + k);
+        o.values[k] = argv[i];
+    }
+    return o;
+}
+
+int64_t positive_i64(const options_t &o, const char *name) {
+    if (!o.has(name))
+        throw std::runtime_error(std::string("missing --") + name);
+    char *end = nullptr;
+    long long v = std::strtoll(o.get(name).c_str(), &end, 10);
+    if (!end || *end || v <= 0)
+        throw std::runtime_error(std::string("invalid --") + name);
+    return v;
+}
+
+std::string read_file(const std::string &path) {
+    std::ifstream f(path.c_str(), std::ios::binary);
+    if (!f) throw std::runtime_error("cannot open " + path);
+    return std::string((std::istreambuf_iterator<char>(f)), {});
+}
+std::string json_escape(const std::string &s) {
+    std::string out;
+    for (char c : s) {
+        switch (c) {
+            case '\\': out += "\\\\"; break;
+            case '"': out += "\\\""; break;
+            case '\n': out += "\\n"; break;
+            case '\r': out += "\\r"; break;
+            case '\t': out += "\\t"; break;
+            default: out += c; break;
+        }
+    }
+    return out;
+}
+void write_file(const std::string &path, const std::string &text) {
+    const std::string temporary = path + ".tmp." + std::to_string(getpid());
+    {
+        std::ofstream f(temporary.c_str(), std::ios::binary | std::ios::trunc);
+        if (!f || !(f << text))
+            throw std::runtime_error("cannot write " + temporary);
+    }
+    if (std::rename(temporary.c_str(), path.c_str()) != 0)
+        throw std::runtime_error("cannot atomically replace " + path);
+}
+void append_line(const std::string &path, const std::string &line) {
+    std::ofstream f(path.c_str(), std::ios::binary | std::ios::app);
+    if (!f || !(f << line << '\n'))
+        throw std::runtime_error("cannot append " + path);
+}
+
+void discard_truncated_history_tail(const std::string &path) {
+    std::ifstream f(path.c_str(), std::ios::binary);
+    if (!f) return;
+    std::string text((std::istreambuf_iterator<char>(f)), {});
+    if (text.empty() || text.back() == '\n') return;
+    const size_t last = text.find_last_of('\n');
+    text.resize(last == std::string::npos ? 0 : last + 1);
+    std::ofstream out(path.c_str(), std::ios::binary | std::ios::trunc);
+    if (!out || !(out << text))
+        throw std::runtime_error("cannot recover " + path);
+}
+
+bool json_number(const std::string &s, const char *name, double &out) {
+    const std::string key = std::string("\"") + name + "\"";
+    size_t p = s.find(key);
+    if (p == std::string::npos) return false;
+    p += key.size();
+    while (p < s.size() && std::isspace(static_cast<unsigned char>(s[p])))
+        ++p;
+    if (p == s.size() || s[p++] != ':') return false;
+    while (p < s.size() && std::isspace(static_cast<unsigned char>(s[p])))
+        ++p;
+    std::istringstream in(s.substr(p));
+    in >> out;
+    return !in.fail();
+}
+bool json_string(const std::string &s, const char *name, std::string &out) {
+    const std::string key = std::string("\"") + name + "\"";
+    size_t p = s.find(key);
+    if (p == std::string::npos) return false;
+    p += key.size();
+    while (p < s.size() && std::isspace(static_cast<unsigned char>(s[p])))
+        ++p;
+    if (p == s.size() || s[p++] != ':') return false;
+    while (p < s.size() && std::isspace(static_cast<unsigned char>(s[p])))
+        ++p;
+    if (p == s.size() || s[p++] != '"') return false;
+    size_t e = s.find('"', p);
+    if (e == std::string::npos) return false;
+    out = s.substr(p, e - p);
+    return true;
+}
+
+std::map<uint64_t, candidate_t> load_completed_history(
+        const std::string &path) {
+    std::map<uint64_t, candidate_t> completed;
+    std::ifstream f(path.c_str());
+    std::string line;
+    while (std::getline(f, line)) {
+        std::string state, hash_text, error;
+        if (!json_string(line, "state", state) || state != "benchmarked"
+                || !json_string(line, "candidate_hash", hash_text))
+            continue;
+        candidate_t c;
+        if (!parse_plan_json(line, c.plan, error)) continue;
+        std::istringstream hex(hash_text);
+        hex >> std::hex >> c.hash;
+        double scratch = 0, packed = 0;
+        if (!json_number(line, "one_shot_ms", c.measurement.one_shot_ms)
+                || !json_number(line, "steady_ms", c.measurement.steady_ms)
+                || !json_number(line, "throughput_gflops",
+                        c.measurement.throughput_gflops)
+                || !json_number(line, "median_ms", c.measurement.median_ms)
+                || !json_number(line, "minimum_ms", c.measurement.minimum_ms)
+                || !json_number(line, "p90_ms", c.measurement.p90_ms)
+                || !json_number(line, "packing_ms", c.measurement.packing_ms)
+                || !json_number(line, "packed_gbps", c.measurement.packed_gbps)
+                || !json_number(line, "compute_ms", c.measurement.compute_ms)
+                || !json_number(line, "scratchpad_bytes", scratch)
+                || !json_number(line, "packed_bytes", packed))
+            continue;
+        c.measurement.scratchpad_bytes = static_cast<size_t>(scratch);
+        c.measurement.packed_bytes = static_cast<size_t>(packed);
+        c.measurement.correct
+                = line.find("\"correct\":true") != std::string::npos;
+        c.measurement.stable
+                = line.find("\"stable\":true") != std::string::npos;
+        completed[c.hash] = c;
+    }
+    return completed;
+}
+
+std::vector<int> parse_cpu_mask(const std::string &text) {
+    if (text.empty())
+        throw std::runtime_error("an explicit --cpus mask is required");
+    std::set<int> cpus;
+    std::istringstream in(text);
+    std::string part;
+    while (std::getline(in, part, ',')) {
+        size_t dash = part.find('-');
+        int first = -1, last = -1;
+        try {
+            first = std::stoi(part.substr(0, dash));
+            last = dash == std::string::npos ? first
+                                             : std::stoi(part.substr(dash + 1));
+        } catch (...) { throw std::runtime_error("invalid CPU mask: " + text); }
+        if (first < 0 || last < first || last >= CPU_SETSIZE)
+            throw std::runtime_error("invalid CPU mask: " + text);
+        for (int c = first; c <= last; ++c)
+            cpus.insert(c);
+    }
+    return std::vector<int>(cpus.begin(), cpus.end());
+}
+
+void pin_and_verify(const std::string &mask, int threads) {
+    const auto cpus = parse_cpu_mask(mask);
+    if (threads > static_cast<int>(cpus.size()))
+        throw std::runtime_error(
+                "--threads exceeds the number of CPUs in --cpus");
+    cpu_set_t set;
+    CPU_ZERO(&set);
+    for (int c : cpus)
+        CPU_SET(c, &set);
+    if (sched_setaffinity(0, sizeof(set), &set) != 0)
+        throw std::runtime_error(std::string("sched_setaffinity failed: ")
+                + std::strerror(errno));
+    setenv("OMP_PROC_BIND", "close", 1);
+    setenv("OMP_PLACES", "cores", 1);
+    omp_set_dynamic(0);
+    omp_set_num_threads(threads);
+    int bad = 0, observed = 0;
+#pragma omp parallel reduction(+ : bad, observed)
+    {
+        int cpu = sched_getcpu();
+        observed += 1;
+        if (cpu < 0 || !CPU_ISSET(cpu, &set)) bad += 1;
+    }
+    if (observed != threads || bad)
+        throw std::runtime_error(
+                "OpenMP workers did not remain inside the exact CPU mask");
+}
+
+std::string first_matching_line(const char *path, const std::string &needle) {
+    std::ifstream f(path);
+    std::string line;
+    while (std::getline(f, line))
+        if (line.find(needle) != std::string::npos) return line;
+    return "unknown";
+}
+std::string machine_identity(int threads, const std::string &mask) {
+    const auto *v = dnnl::version();
+    const auto isa = dnnl_get_effective_cpu_isa();
+    std::ostringstream os;
+    os << first_matching_line("/proc/cpuinfo", "model name")
+       << ";isa=" << dnnl_cpu_isa2str(isa) << ";vector_bits="
+       << (std::string(dnnl_cpu_isa2str(isa)).find("AVX512")
+                                  != std::string::npos
+                          ? 512
+                          : 256)
+       << ";L1="
+       << first_matching_line(
+                  "/sys/devices/system/cpu/cpu0/cache/index0/size", "")
+       << ";L2="
+       << first_matching_line(
+                  "/sys/devices/system/cpu/cpu0/cache/index2/size", "")
+       << ";L3="
+       << first_matching_line(
+                  "/sys/devices/system/cpu/cpu0/cache/index3/size", "")
+       << ";threads=" << threads << ";mask=" << mask
+       << ";onednn=" << (v->hash ? v->hash : "unknown")
+       << ";compiler=" << __VERSION__
+       << ";matopt_patch=external-v2;protocol=1;schema=1"
+       << ";build_reorder=" << BUILD_REORDER;
+    return os.str();
+}
+
+unsigned parse_objectives(const std::string &s) {
+    unsigned out = 0;
+    std::istringstream in(s);
+    std::string x;
+    while (std::getline(in, x, ',')) {
+        if (x == "one-shot")
+            out |= one_shot;
+        else if (x == "steady-state")
+            out |= steady;
+        else if (x == "throughput")
+            out |= throughput;
+        else
+            throw std::runtime_error("invalid objective: " + x);
+    }
+    if (!out) throw std::runtime_error("at least one objective is required");
+    return out;
+}
+
+workload_t workload_from_options(const options_t &o) {
+    workload_t w;
+    w.M = positive_i64(o, "m");
+    w.N = positive_i64(o, "n");
+    w.K = positive_i64(o, "k");
+    w.threads = static_cast<int>(positive_i64(o, "threads"));
+    w.cpus = o.get("cpus");
+    parse_cpu_mask(w.cpus);
+    w.objectives = parse_objectives(
+            o.get("objectives", "one-shot,steady-state,throughput"));
+#if defined(DNNL_AARCH64) && DNNL_AARCH64
+    w.allow_split_k = false;
+#endif
+    return w;
+}
+
+workload_t workload_from_request(const std::string &request) {
+    workload_t w;
+    double protocol = 0, m = 0, n = 0, k = 0, threads = 0, alpha = 0, beta = 0;
+    std::string dtype, layout;
+    if (!json_number(request, "protocol_version", protocol) || protocol != 1
+            || !json_number(request, "m", m) || !json_number(request, "n", n)
+            || !json_number(request, "k", k)
+            || !json_number(request, "threads", threads)
+            || !json_string(request, "cpus", w.cpus)
+            || !json_string(request, "dtype", dtype)
+            || !json_string(request, "layout", layout)
+            || !json_number(request, "alpha", alpha)
+            || !json_number(request, "beta", beta) || dtype != "f32"
+            || layout != "dense_row_major" || alpha != 1 || beta != 0 || m <= 0
+            || n <= 0 || k <= 0 || threads <= 0) {
+        throw std::runtime_error("missing or invalid workload field");
+    }
+    w.M = static_cast<int64_t>(m);
+    w.N = static_cast<int64_t>(n);
+    w.K = static_cast<int64_t>(k);
+    w.threads = static_cast<int>(threads);
+    parse_cpu_mask(w.cpus);
+#if defined(DNNL_AARCH64) && DNNL_AARCH64
+    w.allow_split_k = false;
+#endif
+    return w;
+}
+
+struct measurement_profile_t {
+    int warmups = 3;
+    int samples = 3;
+    double minimum_sample_ms = 100;
+};
+
+measurement_profile_t profile_from_request(const std::string &request) {
+    measurement_profile_t p;
+    double value = 0;
+    if (json_number(request, "warmups", value))
+        p.warmups = static_cast<int>(value);
+    if (json_number(request, "samples", value))
+        p.samples = static_cast<int>(value);
+    if (json_number(request, "minimum_sample_ms", value))
+        p.minimum_sample_ms = value;
+    if (p.warmups < 0 || p.samples <= 0 || p.samples > 100
+            || p.minimum_sample_ms <= 0 || p.minimum_sample_ms > 60000)
+        throw std::runtime_error("invalid measurement profile");
+    return p;
+}
+
+struct data_t {
+    std::vector<float> A, B, reference;
+    memory::desc a_md, b_md, c_md;
+    data_t(const workload_t &w)
+        : A(static_cast<size_t>(w.M * w.K))
+        , B(static_cast<size_t>(w.K * w.N))
+        , reference(static_cast<size_t>(w.M * w.N))
+        , a_md({w.M, w.K}, memory::data_type::f32, memory::format_tag::ab)
+        , b_md({w.K, w.N}, memory::data_type::f32, memory::format_tag::ab)
+        , c_md({w.M, w.N}, memory::data_type::f32, memory::format_tag::ab) {
+        for (size_t i = 0; i < A.size(); ++i)
+            A[i] = static_cast<float>(static_cast<int>(i % 7) - 3);
+        for (size_t i = 0; i < B.size(); ++i)
+            B[i] = static_cast<float>(static_cast<int>(i % 5) - 2);
+        // Deterministic non-integral samples exercise FP paths without making
+        // the exact-integer bulk validation sensitive to reduction order.
+        for (size_t i = 0; i < A.size(); i += 4093)
+            A[i] += 0.125f;
+        for (size_t i = 0; i < B.size(); i += 4099)
+            B[i] -= 0.25f;
+    }
+};
+
+struct case_t {
+    matmul::primitive_desc pd;
+    matmul primitive;
+    memory a, b_plain, b_exec, c, scratchpad;
+    stream strm;
+    bool persistent;
+    finalized_plan_t finalized;
+    case_t(engine &eng, data_t &d, const plan_t *plan)
+        : a(d.a_md, eng, d.A.data())
+        , b_plain(d.b_md, eng, d.B.data())
+        , strm(eng)
+        , persistent(plan
+                  && (plan->pack_b == pack_b_t::persistent_n32
+                          || plan->pack_b == pack_b_t::persistent_n64)) {
+        dnnl::impl::cpu::matopt::clear_capture();
+        backend scope(plan);
+        const auto requested_b = persistent
+                ? memory::desc(d.b_md.get_dims(), memory::data_type::f32,
+                          memory::format_tag::any)
+                : d.b_md;
+        primitive_attr attr;
+        attr.set_scratchpad_mode(scratchpad_mode::user);
+        pd = matmul::primitive_desc(eng, d.a_md, requested_b, d.c_md, attr);
+        primitive = matmul(pd);
+        b_exec = persistent ? memory(pd.weights_desc(), eng) : b_plain;
+        c = memory(d.c_md, eng);
+        if (pd.scratchpad_desc().get_size() != 0)
+            scratchpad = memory(pd.scratchpad_desc(), eng);
+        if (persistent) {
+            reorder(b_plain, b_exec).execute(strm, b_plain, b_exec);
+            strm.wait();
+        }
+        const bool captured = dnnl::impl::cpu::matopt::get_capture(finalized);
+        if (plan && (!captured || finalized.realized_bd_block == 0)) {
+            std::string why = dnnl::impl::cpu::matopt::get_error();
+            throw std::runtime_error(why.empty() ? "plan did not instantiate "
+                                                   "the BRGEMM MatMul backend"
+                                                 : why);
+        }
+        if (plan
+                && ((plan->bd_block
+                            && finalized.realized_bd_block != plan->bd_block)
+                        || (plan->ld_block2
+                                && finalized.realized_ld_block2
+                                        != plan->ld_block2)))
+            throw std::runtime_error(
+                    "backend did not realize the requested microtile");
+        finalized.scratchpad_bytes = pd.scratchpad_desc().get_size();
+        if (plan
+                && finalized.scratchpad_bytes
+                        > static_cast<size_t>(omp_get_max_threads()) * 64ULL
+                                * 1024 * 1024)
+            throw std::runtime_error(
+                    "realized scratchpad exceeds 64 MiB per thread");
+    }
+    void reorder_b() {
+        if (persistent) {
+            reorder(b_plain, b_exec).execute(strm, b_plain, b_exec);
+            strm.wait();
+        }
+    }
+    void execute() {
+        std::unordered_map<int, memory> args {{DNNL_ARG_SRC, a},
+                {DNNL_ARG_WEIGHTS, b_exec}, {DNNL_ARG_DST, c}};
+        if (pd.scratchpad_desc().get_size() != 0)
+            args.emplace(DNNL_ARG_SCRATCHPAD, scratchpad);
+        primitive.execute(strm, args);
+        strm.wait();
+    }
+};
+
+double elapsed_ms(const clock_t::time_point &a, const clock_t::time_point &b) {
+    return std::chrono::duration<double, std::milli>(b - a).count();
+}
+
+std::vector<double> sample(
+        case_t &c, int samples, double min_total_ms, bool include_reorder) {
+    std::vector<double> values;
+    values.reserve(samples);
+    for (int s = 0; s < samples; ++s) {
+        int iters = 1;
+        double duration = 0;
+        do {
+            auto begin = clock_t::now();
+            for (int i = 0; i < iters; ++i) {
+                if (include_reorder) c.reorder_b();
+                c.execute();
+            }
+            duration = elapsed_ms(begin, clock_t::now());
+            if (duration < min_total_ms)
+                iters = std::max(iters + 1,
+                        static_cast<int>(std::ceil(iters * min_total_ms
+                                / std::max(duration, 0.001))));
+        } while (duration < min_total_ms);
+        values.push_back(duration / iters);
+    }
+    std::sort(values.begin(), values.end());
+    return values;
+}
+
+measurement_t benchmark_case(case_t &c, data_t &d, const workload_t &w,
+        int samples, double min_ms, bool validate, int warmups = 3) {
+    measurement_t m;
+    for (int i = 0; i < warmups; ++i)
+        c.execute();
+    if (validate) {
+        const float *got = static_cast<const float *>(c.c.get_data_handle());
+        size_t bad = 0;
+        for (size_t i = 0; i < d.reference.size(); ++i) {
+            const float tol = 2e-4f * std::max(1.f, std::fabs(d.reference[i]));
+            if (std::fabs(got[i] - d.reference[i]) > tol) {
+                ++bad;
+                if (bad == 8) break;
+            }
+        }
+        m.correct = bad == 0;
+        if (!m.correct) return m;
+    } else
+        m.correct = true;
+    if (c.persistent) {
+        auto begin = clock_t::now();
+        for (int i = 0; i < 3; ++i)
+            c.reorder_b();
+        m.packing_ms = elapsed_ms(begin, clock_t::now()) / 3.0;
+        m.packed_bytes = c.pd.weights_desc().get_size();
+        m.packed_gbps = m.packed_bytes / (m.packing_ms * 1e6);
+    }
+    auto steady_samples = sample(c, samples, min_ms, false);
+    auto one_samples
+            = c.persistent ? sample(c, samples, min_ms, true) : steady_samples;
+    const size_t p90 = std::min(one_samples.size() - 1,
+            static_cast<size_t>(std::ceil(0.9 * one_samples.size()) - 1));
+    m.minimum_ms = one_samples.front();
+    m.median_ms = one_samples[one_samples.size() / 2];
+    m.p90_ms = one_samples[p90];
+    m.one_shot_ms = m.median_ms;
+    m.steady_ms = steady_samples[steady_samples.size() / 2];
+    m.compute_ms = m.steady_ms;
+    m.throughput_gflops = 2.0 * w.M * w.N * w.K / (m.steady_ms * 1e6);
+    m.scratchpad_bytes = c.finalized.scratchpad_bytes;
+    m.stable
+            = m.median_ms > 0 && (m.p90_ms - m.median_ms) / m.median_ms <= 0.05;
+    return m;
+}
+
+void make_reference(engine &eng, data_t &d) {
+    case_t baseline(eng, d, nullptr);
+    baseline.execute();
+    std::memcpy(d.reference.data(), baseline.c.get_data_handle(),
+            d.reference.size() * sizeof(float));
+}
+
+plan_t replay_plan(const finalized_plan_t &f) {
+    plan_t p = f;
+    p.pack_a = f.use_buffer_a ? pack_a_t::per_call_padded : pack_a_t::direct;
+    if (f.blocked_B)
+        p.pack_b = f.N_blk == 32 ? pack_b_t::persistent_n32
+                                 : pack_b_t::persistent_n64;
+    else if (f.use_buffer_b)
+        p.pack_b = f.N_blk == 32 ? pack_b_t::per_call_n32
+                                 : pack_b_t::per_call_n64;
+    else
+        p.pack_b = pack_b_t::direct;
+    p.K_chunk_size = std::max(1, p.K_chunk_size);
+    p.bd_block = 0;
+    p.ld_block2 = 0;
+    p.loop_order = loop_order_t::default_order;
+    return p;
+}
+
+std::string history_record(const std::string &key, const char *state,
+        const candidate_t &c, const std::string &reason = "") {
+    std::ostringstream os;
+    os << "{\"resume_key\":\"" << key << "\",\"state\":\"" << state
+       << "\",\"candidate_hash\":\"" << std::hex << c.hash << std::dec
+       << "\",\"plan\":" << plan_json(c.plan);
+    if (!reason.empty()) os << ",\"reason\":\"" << json_escape(reason) << "\"";
+    if (std::string(state) == "benchmarked")
+        os << ",\"measurement\":" << measurement_json(c.measurement);
+    os << "}";
+    return os.str();
+}
+
+void inspect_command(const options_t &o) {
+    if (!o.has("plan")) throw std::runtime_error("inspect requires --plan");
+    plan_t p;
+    std::string error;
+    if (!parse_plan_json(read_file(o.get("plan")), p, error))
+        throw std::runtime_error(error);
+    std::cout << plan_json(p) << '\n';
+    std::cout << "estimated_scratchpad_per_thread=" << estimate_scratchpad(p)
+              << " bytes\n";
+}
+
+void benchmark_command(const options_t &o) {
+    workload_t w = workload_from_options(o);
+    pin_and_verify(w.cpus, w.threads);
+    dnnl::set_primitive_cache_capacity(0);
+    plan_t p;
+    std::string error;
+    if (!o.has("plan") || !parse_plan_json(read_file(o.get("plan")), p, error))
+        throw std::runtime_error(
+                o.has("plan") ? error : "benchmark requires --plan");
+    if (!(error = validate_plan(w, p)).empty()) throw std::runtime_error(error);
+    engine eng(engine::kind::cpu, 0);
+    data_t d(w);
+    make_reference(eng, d);
+    case_t tuned(eng, d, &p);
+    auto result = benchmark_case(tuned, d, w, 15, 1000, true);
+    std::cout << "{\"finalized\":" << finalized_json(tuned.finalized)
+              << ",\"measurement\":" << measurement_json(result) << "}" << '\n';
+    if (o.has("compare-default")) {
+        case_t def(eng, d, nullptr);
+        auto base = benchmark_case(def, d, w, 15, 1000, true);
+        std::cout << "{\"default\":" << measurement_json(base) << "}" << '\n';
+    }
+}
+
+void tune_command(const options_t &o) {
+    workload_t w = workload_from_options(o);
+    if (!o.has("history") || !o.has("output"))
+        throw std::runtime_error("tune requires --history and --output");
+    pin_and_verify(w.cpus, w.threads);
+    dnnl::set_primitive_cache_capacity(0);
+    const std::string identity = machine_identity(w.threads, w.cpus);
+    const std::string key = workload_key(w, identity);
+    size_t old_records = 0;
+    std::string error;
+    if (!validate_history(o.get("history"), key, old_records, error))
+        throw std::runtime_error(error);
+    discard_truncated_history_tail(o.get("history"));
+    const auto completed = load_completed_history(o.get("history"));
+    engine eng(engine::kind::cpu, 0);
+    data_t d(w);
+
+    // Capture and replay the current oneDNN heuristic before generating any
+    // mutations. AArch64 temporarily forces the effective tuning baseline to
+    // nthr_k=1, without changing oneDNN's ordinary null-plan behavior.
+    case_t captured_default(eng, d, nullptr);
+    plan_t baseline_plan = replay_plan(captured_default.finalized);
+    if (!w.allow_split_k) baseline_plan.nthr_k = 1;
+    case_t replayed(eng, d, &baseline_plan);
+    const auto &a = captured_default.finalized;
+    const auto &b = replayed.finalized;
+    if (a.M_blk != b.M_blk || a.N_blk != b.N_blk || a.K_blk != b.K_blk
+            || a.M_chunk_size != b.M_chunk_size
+            || a.N_chunk_size != b.N_chunk_size
+            || a.brgemm_batch_size != b.brgemm_batch_size
+            || (w.allow_split_k && a.nthr_k != b.nthr_k)
+            || b.nthr_k != baseline_plan.nthr_k || a.M_tail != b.M_tail
+            || a.N_tail != b.N_tail || a.K_tail != b.K_tail)
+        throw std::runtime_error(
+                "captured default configuration did not replay identically");
+    if (w.allow_split_k) {
+        make_reference(eng, d);
+    } else {
+        replayed.execute();
+        std::memcpy(d.reference.data(), replayed.c.get_data_handle(),
+                d.reference.size() * sizeof(float));
+    }
+
+    std::vector<candidate_t> all;
+    std::vector<unsigned> active_objectives;
+    for (unsigned obj : {one_shot, steady, throughput})
+        if (w.objectives & obj) active_objectives.push_back(obj);
+    candidate_t baseline;
+    baseline.plan = baseline_plan;
+    baseline.hash = stable_hash(plan_json(baseline.plan));
+    auto previous = completed.find(baseline.hash);
+    baseline.measurement = previous == completed.end()
+            ? benchmark_case(replayed, d, w, 3, 100, true)
+            : previous->second.measurement;
+    all.push_back(baseline);
+    if (previous == completed.end())
+        append_line(o.get("history"),
+                history_record(key, "benchmarked", all.back()));
+
+    finalized_plan_t candidate_baseline = captured_default.finalized;
+    static_cast<plan_t &>(candidate_baseline) = baseline_plan;
+    auto macro = generate_candidates(w, candidate_baseline);
+    // Deterministic hash order removes systematic thermal/order bias while
+    // remaining exactly reproducible for the resume key.
+    std::sort(macro.begin(), macro.end(),
+            [&](const candidate_t &x, const candidate_t &y) {
+        return (x.hash ^ stable_hash(key)) < (y.hash ^ stable_hash(key));
+    });
+    for (auto &c : macro) {
+        if (c.hash == baseline.hash) continue;
+        auto done = completed.find(c.hash);
+        if (done != completed.end()) {
+            c.measurement = done->second.measurement;
+            all.push_back(c);
+            continue;
+        }
+        append_line(
+                o.get("history"), history_record(key, "started", c, "macro"));
+        try {
+            case_t run(eng, d, &c.plan);
+            c.measurement = benchmark_case(run, d, w, 3, 100, true);
+            if (!c.measurement.correct)
+                append_line(
+                        o.get("history"), history_record(key, "incorrect", c));
+            else
+                append_line(o.get("history"),
+                        history_record(key, "benchmarked", c));
+            all.push_back(c);
+        } catch (const std::exception &e) {
+            append_line(o.get("history"),
+                    history_record(key, "rejected", c, e.what()));
+        }
+    }
+
+    // Top three per objective seed the micro search.
+    std::set<uint64_t> seeds;
+    for (unsigned obj : active_objectives) {
+        std::vector<size_t> order(all.size());
+        std::iota(order.begin(), order.end(), 0);
+        std::sort(order.begin(), order.end(), [&](size_t x, size_t y) {
+            if (all[x].measurement.correct != all[y].measurement.correct)
+                return all[x].measurement.correct;
+            if (obj == throughput)
+                return all[x].measurement.throughput_gflops
+                        > all[y].measurement.throughput_gflops;
+            return (obj == one_shot ? all[x].measurement.one_shot_ms
+                                    : all[x].measurement.steady_ms)
+                    < (obj == one_shot ? all[y].measurement.one_shot_ms
+                                       : all[y].measurement.steady_ms);
+        });
+        size_t kept = 0;
+        for (size_t i : order) {
+            if (!all[i].measurement.correct) continue;
+            seeds.insert(all[i].hash);
+            if (++kept == 3) break;
+        }
+    }
+    const std::vector<int> bds {0, 4, 5, 6, 7};
+    const std::vector<int> lds {0, 2, 3, 4};
+    std::vector<candidate_t> micro;
+    std::set<uint64_t> micro_seen;
+    for (const auto &seed : all)
+        if (seeds.count(seed.hash))
+            for (int bd : bds)
+                for (int ld : lds)
+                    for (loop_order_t loop : {loop_order_t::default_order,
+                                 loop_order_t::one_load}) {
+                        candidate_t c;
+                        c.plan = seed.plan;
+                        c.plan.bd_block = bd;
+                        c.plan.ld_block2 = ld;
+                        c.plan.loop_order = loop;
+                        c.hash = stable_hash(plan_json(c.plan));
+                        if (c.hash == seed.hash
+                                || !micro_seen.insert(c.hash).second)
+                            continue;
+                        auto done = completed.find(c.hash);
+                        if (done != completed.end()) {
+                            c.measurement = done->second.measurement;
+                            micro.push_back(c);
+                            continue;
+                        }
+                        c.rejection = validate_plan(w, c.plan);
+                        if (!c.rejection.empty()) {
+                            append_line(o.get("history"),
+                                    history_record(
+                                            key, "rejected", c, c.rejection));
+                            continue;
+                        }
+                        append_line(o.get("history"),
+                                history_record(key, "started", c, "micro"));
+                        try {
+                            case_t run(eng, d, &c.plan);
+                            c.measurement
+                                    = benchmark_case(run, d, w, 5, 200, true);
+                            append_line(o.get("history"),
+                                    history_record(key,
+                                            c.measurement.correct
+                                                    ? "benchmarked"
+                                                    : "incorrect",
+                                            c));
+                            if (c.measurement.correct) micro.push_back(c);
+                        } catch (const std::exception &e) {
+                            append_line(o.get("history"),
+                                    history_record(
+                                            key, "rejected", c, e.what()));
+                        }
+                    }
+    all.insert(all.end(), micro.begin(), micro.end());
+
+    // Finalize the best observed candidate for each objective. Unstable
+    // finalists are rerun once and cannot win if still above 5% spread.
+    std::set<size_t> finalist_indices;
+    finalist_indices.insert(0);
+    for (unsigned obj : active_objectives) {
+        size_t idx = choose_candidate(all, obj, 0, 0.0);
+        finalist_indices.insert(idx);
+    }
+    for (size_t idx : finalist_indices) {
+        append_line(o.get("history"),
+                history_record(key, "started", all[idx], "finalist"));
+        case_t run(eng, d, &all[idx].plan);
+        all[idx].measurement = benchmark_case(run, d, w, 15, 1000, true);
+        if (!all[idx].measurement.stable)
+            all[idx].measurement = benchmark_case(run, d, w, 15, 1000, true);
+        append_line(
+                o.get("history"), history_record(key, "benchmarked", all[idx]));
+    }
+    // Baseline noise is its observed high-tail spread.
+    const double noise = all[0].measurement.median_ms > 0
+            ? std::max(0.0,
+                      (all[0].measurement.p90_ms - all[0].measurement.median_ms)
+                              / all[0].measurement.median_ms)
+            : 0.0;
+    const size_t one_idx = (w.objectives & one_shot)
+            ? choose_candidate(all, one_shot, 0, noise)
+            : 0;
+    const size_t steady_idx = (w.objectives & steady)
+            ? choose_candidate(all, steady, 0, noise)
+            : 0;
+    const size_t throughput_idx = (w.objectives & throughput)
+            ? choose_candidate(all, throughput, 0, noise)
+            : 0;
+    const auto pareto = pareto_indices(all);
+    std::ostringstream output;
+    output << "{\"schema_version\":1,\"resume_key\":\"" << key
+           << "\",\"identity\":\"" << json_escape(identity)
+           << "\",\"selected\":{";
+    bool first_selected = true;
+    auto emit_selected = [&](const char *name, size_t idx) {
+        if (!first_selected) output << ',';
+        first_selected = false;
+        output << '\"' << name << "\":" << plan_json(all[idx].plan);
+    };
+    if (w.objectives & one_shot) emit_selected("one-shot", one_idx);
+    if (w.objectives & steady) emit_selected("steady-state", steady_idx);
+    if (w.objectives & throughput) emit_selected("throughput", throughput_idx);
+    output << "},\"pareto\":[";
+    for (size_t i = 0; i < pareto.size(); ++i) {
+        if (i) output << ',';
+        output << "{\"plan\":" << plan_json(all[pareto[i]].plan)
+               << ",\"measurement\":"
+               << measurement_json(all[pareto[i]].measurement) << "}";
+    }
+    output << "]}\n";
+    write_file(o.get("output"), output.str());
+    std::cout << "wrote " << o.get("output") << " with " << pareto.size()
+              << " Pareto plans (history records before run: " << old_records
+              << ")\n";
+}
+
+std::string rejection_code(const std::string &detail) {
+    if (detail.find("split-K") != std::string::npos)
+        return "split_k_unsupported";
+    if (detail.find("thread-count divisor") != std::string::npos)
+        return "invalid_thread_partition";
+    if (detail.find("K granularity") != std::string::npos)
+        return "invalid_k_granularity";
+    if (detail.find("packing") != std::string::npos
+            || detail.find("format") != std::string::npos
+            || detail.find("blocked weights") != std::string::npos)
+        return "packing_layout_mismatch";
+    if (detail.find("K chunks") != std::string::npos)
+        return "insufficient_k_chunks";
+    if (detail.find("scratchpad") != std::string::npos)
+        return "scratchpad_limit_exceeded";
+    if (detail.find("microtile") != std::string::npos
+            || detail.find("register-pressure") != std::string::npos)
+        return "invalid_microtile";
+    return "invalid_plan";
+}
+
+std::string request_id(const std::string &request) {
+    std::string id;
+    if (!json_string(request, "request_id", id) || id.empty())
+        throw std::runtime_error("missing request_id");
+    return id;
+}
+
+std::string fingerprint_for(const workload_t &w, std::string &identity) {
+    identity = machine_identity(w.threads, w.cpus);
+    return workload_key(w, identity);
+}
+
+void check_expected_fingerprint(
+        const std::string &request, const std::string &actual) {
+    std::string expected;
+    if (json_string(request, "expected_fingerprint", expected)
+            && !expected.empty() && expected != actual)
+        throw std::runtime_error("fingerprint mismatch");
+}
+
+void prepare_runner(const workload_t &w) {
+    pin_and_verify(w.cpus, w.threads);
+    dnnl::set_primitive_cache_capacity(0);
+}
+
+void capabilities_command(const options_t &o) {
+    if (!o.has("request"))
+        throw std::runtime_error("capabilities requires --request");
+    const std::string request = read_file(o.get("request"));
+    const std::string id = request_id(request);
+    const workload_t w = workload_from_request(request);
+    prepare_runner(w);
+    std::string identity;
+    const std::string fingerprint = fingerprint_for(w, identity);
+    check_expected_fingerprint(request, fingerprint);
+    const std::string isa = dnnl_cpu_isa2str(dnnl_get_effective_cpu_isa());
+    std::cout << "{\"protocol_version\":1,\"request_id\":\"" << json_escape(id)
+              << "\",\"status\":\"capabilities\"" << ",\"fingerprint\":\""
+              << fingerprint << "\"" << ",\"identity\":\""
+              << json_escape(identity) << "\"" << ",\"effective_isa\":\""
+              << json_escape(isa) << "\"" << ",\"plan_schema_version\":1"
+              << ",\"workload_domain\":{\"dtype\":[\"f32\"],"
+                 "\"layout\":[\"dense_row_major\"],\"alpha\":[1],"
+                 "\"beta\":[0]}"
+              << ",\"constraints\":{\"allow_split_k\":"
+              << (w.allow_split_k ? "true" : "false")
+              << ",\"scratchpad_per_thread_bytes\":67108864}"
+              << ",\"domains\":{\"pack_a\":[\"direct\","
+                 "\"per_call_padded\"],\"pack_b\":[\"direct\","
+                 "\"per_call_n32\",\"per_call_n64\","
+                 "\"persistent_n32\",\"persistent_n64\"],"
+                 "\"bd_block\":[0,4,5,6,7],"
+                 "\"ld_block2\":[0,2,3,4],"
+                 "\"loop_order\":[\"default\",\"one-load\"]}}\n";
+}
+
+struct baseline_t {
+    finalized_plan_t captured;
+    plan_t effective;
+    finalized_plan_t finalized;
+    measurement_t measurement;
+};
+
+baseline_t run_baseline(const workload_t &w, const measurement_profile_t &p) {
+    engine eng(engine::kind::cpu, 0);
+    data_t data(w);
+    case_t captured(eng, data, nullptr);
+    plan_t effective = replay_plan(captured.finalized);
+    if (!w.allow_split_k) effective.nthr_k = 1;
+    case_t replayed(eng, data, &effective);
+    const auto &a = captured.finalized;
+    const auto &b = replayed.finalized;
+    if (a.M_blk != b.M_blk || a.N_blk != b.N_blk || a.K_blk != b.K_blk
+            || a.M_chunk_size != b.M_chunk_size
+            || a.N_chunk_size != b.N_chunk_size
+            || a.brgemm_batch_size != b.brgemm_batch_size
+            || (w.allow_split_k && a.nthr_k != b.nthr_k)
+            || b.nthr_k != effective.nthr_k || a.M_tail != b.M_tail
+            || a.N_tail != b.N_tail || a.K_tail != b.K_tail)
+        throw std::runtime_error(
+                "captured default configuration did not replay identically");
+    if (w.allow_split_k) {
+        make_reference(eng, data);
+    } else {
+        replayed.execute();
+        std::memcpy(data.reference.data(), replayed.c.get_data_handle(),
+                data.reference.size() * sizeof(float));
+    }
+    baseline_t out;
+    out.captured = captured.finalized;
+    out.effective = effective;
+    out.finalized = replayed.finalized;
+    out.measurement = benchmark_case(
+            replayed, data, w, p.samples, p.minimum_sample_ms, true, p.warmups);
+    return out;
+}
+
+void baseline_command(const options_t &o) {
+    if (!o.has("request"))
+        throw std::runtime_error("baseline requires --request");
+    const std::string request = read_file(o.get("request"));
+    const std::string id = request_id(request);
+    const workload_t w = workload_from_request(request);
+    const measurement_profile_t profile = profile_from_request(request);
+    prepare_runner(w);
+    std::string identity;
+    const std::string fingerprint = fingerprint_for(w, identity);
+    check_expected_fingerprint(request, fingerprint);
+    const baseline_t result = run_baseline(w, profile);
+    std::cout << "{\"protocol_version\":1,\"request_id\":\"" << json_escape(id)
+              << "\",\"status\":\"benchmarked\"" << ",\"fingerprint\":\""
+              << fingerprint << "\""
+              << ",\"captured_default\":" << finalized_json(result.captured)
+              << ",\"effective_plan\":" << plan_json(result.effective)
+              << ",\"finalized\":" << finalized_json(result.finalized)
+              << ",\"measurement\":" << measurement_json(result.measurement)
+              << "}\n";
+}
+
+void evaluate_command(const options_t &o, bool inspect_only) {
+    if (!o.has("request"))
+        throw std::runtime_error("evaluate requires --request");
+    const std::string request = read_file(o.get("request"));
+    const std::string id = request_id(request);
+    const workload_t w = workload_from_request(request);
+    const measurement_profile_t profile = profile_from_request(request);
+    prepare_runner(w);
+    std::string identity;
+    const std::string fingerprint = fingerprint_for(w, identity);
+    check_expected_fingerprint(request, fingerprint);
+    plan_t plan;
+    std::string detail;
+    if (!parse_plan_json(request, plan, detail))
+        throw std::runtime_error(detail);
+    detail = validate_plan(w, plan);
+    try {
+        if (!detail.empty()) throw std::runtime_error(detail);
+        engine eng(engine::kind::cpu, 0);
+        data_t data(w);
+        if (!inspect_only) {
+            if (w.allow_split_k) {
+                make_reference(eng, data);
+            } else {
+                case_t captured(eng, data, nullptr);
+                plan_t safe = replay_plan(captured.finalized);
+                safe.nthr_k = 1;
+                case_t reference(eng, data, &safe);
+                reference.execute();
+                std::memcpy(data.reference.data(),
+                        reference.c.get_data_handle(),
+                        data.reference.size() * sizeof(float));
+            }
+        }
+        case_t evaluated(eng, data, &plan);
+        if (inspect_only) {
+            std::cout << "{\"protocol_version\":1,\"request_id\":\""
+                      << json_escape(id) << "\",\"status\":\"accepted\""
+                      << ",\"fingerprint\":\"" << fingerprint << "\""
+                      << ",\"finalized\":"
+                      << finalized_json(evaluated.finalized) << "}\n";
+            return;
+        }
+        measurement_t measured
+                = benchmark_case(evaluated, data, w, profile.samples,
+                        profile.minimum_sample_ms, true, profile.warmups);
+        std::cout << "{\"protocol_version\":1,\"request_id\":\""
+                  << json_escape(id) << "\",\"status\":\""
+                  << (measured.correct ? "benchmarked" : "incorrect") << "\""
+                  << ",\"fingerprint\":\"" << fingerprint << "\""
+                  << ",\"finalized\":" << finalized_json(evaluated.finalized)
+                  << ",\"measurement\":" << measurement_json(measured) << "}\n";
+    } catch (const std::exception &e) {
+        detail = e.what();
+        std::cout << "{\"protocol_version\":1,\"request_id\":\""
+                  << json_escape(id) << "\",\"status\":\"rejected\""
+                  << ",\"fingerprint\":\"" << fingerprint << "\""
+                  << ",\"reason_code\":\"" << rejection_code(detail)
+                  << "\",\"detail\":\"" << json_escape(detail) << "\"}\n";
+    }
+}
+
+void usage() {
+    std::cerr << "usage:\n"
+              << "  matopt tune --m M --n N --k K --threads T --cpus MASK "
+                 "--objectives LIST --history H --output O\n"
+              << "  matopt benchmark --plan P --m M --n N --k K --threads T "
+                 "--cpus MASK [--compare-default]\n"
+              << "  matopt inspect --plan P\n";
+}
+} // namespace
+
+int main(int argc, char **argv) {
+    try {
+        options_t o = parse_args(argc, argv);
+        if (o.command == "tune")
+            tune_command(o);
+        else if (o.command == "benchmark")
+            benchmark_command(o);
+        else if (o.command == "inspect") {
+            if (o.has("request"))
+                evaluate_command(o, true);
+            else
+                inspect_command(o);
+        } else if (o.command == "capabilities")
+            capabilities_command(o);
+        else if (o.command == "baseline")
+            baseline_command(o);
+        else if (o.command == "evaluate")
+            evaluate_command(o, false);
+        else
+            throw std::runtime_error("unknown command: " + o.command);
+        return 0;
+    } catch (const std::exception &e) {
+        std::cerr << "matopt: " << e.what() << '\n';
+        usage();
+        return 2;
+    }
+}
