+* Licensed under the Apache License, Version 2.0 (the "License");
+*******************************************************************************/
+
+#ifndef CPU_MATMUL_MATOPT_COPY_A_HPP
+#define CPU_MATMUL_MATOPT_COPY_A_HPP
+
+#include <cassert>
+#include <cstddef>
+#include <cstring>
+
+#include "common/c_types_map.hpp"
+
+namespace dnnl {
+namespace impl {
+namespace cpu {
+namespace matopt {
+
+// Correctness-first dense FP32 copy used by the AArch64 MatOpt padded-A path
+// until its currently stubbed SVE copy-A JIT is implemented. Strides are in
+// bytes for the source and in FP32 elements for the destination.
+inline void copy_a_f32(const void *src, void *dst, dim_t rows, dim_t columns,
+        dim_t src_stride_bytes, dim_t dst_ld) {
+    assert(rows >= 0 && columns >= 0 && dst_ld >= columns);
+    const size_t copied_bytes = static_cast<size_t>(columns) * sizeof(float);
+    const size_t padded_bytes
+            = static_cast<size_t>(dst_ld - columns) * sizeof(float);
+    const char *src_row = static_cast<const char *>(src);
+    char *dst_row = static_cast<char *>(dst);
+    for (dim_t m = 0; m < rows; ++m) {
+        std::memcpy(dst_row, src_row, copied_bytes);
+        if (padded_bytes) std::memset(dst_row + copied_bytes, 0, padded_bytes);
+        src_row += src_stride_bytes;
+        dst_row += static_cast<size_t>(dst_ld) * sizeof(float);
+    }
+}
+
+} // namespace matopt
+} // namespace cpu
+} // namespace impl
+} // namespace dnnl
+
+#endif
