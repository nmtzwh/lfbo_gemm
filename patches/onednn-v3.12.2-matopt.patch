+/*******************************************************************************
+* Copyright 2026
+* Licensed under the Apache License, Version 2.0 (the "License");
+******************************************************************************/
+#ifndef TOOLS_MATOPT_CORE_HPP
+#define TOOLS_MATOPT_CORE_HPP
+
+#include <cstdint>
+#include <string>
+#include <vector>
+
+#include "cpu/matmul/matopt_backend.hpp"
+
+namespace matopt_tool {
+
+using dnnl::impl::cpu::matopt::finalized_plan_t;
+using dnnl::impl::cpu::matopt::loop_order_t;
+using dnnl::impl::cpu::matopt::pack_a_t;
+using dnnl::impl::cpu::matopt::pack_b_t;
+using dnnl::impl::cpu::matopt::plan_t;
+
+enum objective_bits { one_shot = 1, steady = 2, throughput = 4 };
+
+struct workload_t {
+    uint32_t version = dnnl::impl::cpu::matopt::schema_version;
+    int64_t M = 0, N = 0, K = 0;
+    int threads = 0;
+    std::string cpus;
+    unsigned objectives = one_shot | steady | throughput;
+    float alpha = 1.f;
+    float beta = 0.f;
+    bool allow_split_k = true;
+};
+
+struct measurement_t {
+    double one_shot_ms = 0;
+    double steady_ms = 0;
+    double throughput_gflops = 0;
+    double median_ms = 0;
+    double minimum_ms = 0;
+    double p90_ms = 0;
+    double packing_ms = 0;
+    double packed_gbps = 0;
+    double compute_ms = 0;
+    size_t packed_bytes = 0;
+    size_t scratchpad_bytes = 0;
+    bool correct = false;
+    bool stable = true;
+};
+
+struct candidate_t {
+    plan_t plan;
+    uint64_t hash = 0;
+    double rank = 0;
+    std::string rejection;
+    measurement_t measurement;
+};
+
+uint64_t stable_hash(const std::string &s);
+std::string workload_key(const workload_t &w, const std::string &identity);
+std::string plan_json(const plan_t &p);
+bool parse_plan_json(const std::string &json, plan_t &p, std::string &error);
+std::string finalized_json(const finalized_plan_t &p);
+std::string measurement_json(const measurement_t &m);
+std::string pack_a_name(pack_a_t v);
+std::string pack_b_name(pack_b_t v);
+std::string loop_order_name(loop_order_t v);
+
+std::vector<candidate_t> generate_candidates(const workload_t &w,
+        const finalized_plan_t &baseline, size_t cap = 256);
+std::string validate_plan(const workload_t &w, const plan_t &p,
+        size_t scratch_limit = 64ULL * 1024 * 1024);
+size_t estimate_scratchpad(const plan_t &p);
+std::vector<size_t> pareto_indices(const std::vector<candidate_t> &candidates);
+size_t choose_candidate(const std::vector<candidate_t> &candidates,
+        unsigned objective, size_t baseline_index, double baseline_noise);
+
+// Reads append-only JSONL. Only an unterminated malformed final record is
+// recoverable. Every complete record must contain the exact resume key.
+bool validate_history(const std::string &path, const std::string &resume_key,
+        size_t &records, std::string &error);
+
+} // namespace matopt_tool
+#endif
